{
    "id": "org.kde.kwordquiz",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kwordquiz",
    "rename-icon": "kwordquiz",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=wayland"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "libkeduvocdocument",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/libkeduvocdocument-26.04.0.tar.xz",
                    "sha256": "032689e3af4da9ce578bfa8efb8945d214556a09ddff412a5c2f8d5be720d653",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/libkeduvocdocument-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "kwordquiz",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/kwordquiz-26.04.0.tar.xz",
                    "sha256": "affe58681df903a4f100ae2afca3b23a66ad0b3434bf4a6f0491115d50d60f06",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kwordquiz-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
