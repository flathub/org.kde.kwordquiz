{
    "id": "org.kde.kwordquiz",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kwordquiz",
    "rename-icon": "kwordquiz",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=wayland"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "libkeduvocdocument",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.1/src/libkeduvocdocument-26.04.1.tar.xz",
                    "sha256": "2994fa1b3c66dcb20d969147fffef28faf375c073b29aeda37db5f3432c21e29",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/libkeduvocdocument-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "kwordquiz",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.1/src/kwordquiz-26.04.1.tar.xz",
                    "sha256": "e0e802a78ac5f410d3c16cdcd4f2fddbce26b40c6e2b9525aa324a1e7aa45dc9",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kwordquiz-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
