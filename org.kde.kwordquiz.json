{
    "id": "org.kde.kwordquiz",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kwordquiz",
    "rename-icon": "kwordquiz",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=wayland"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "libkeduvocdocument",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/libkeduvocdocument-25.12.3.tar.xz",
                    "sha256": "92a680125c75bb9d419d36335bdce78510ff74d3b892b3573729a19cae18752d",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/libkeduvocdocument-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "kwordquiz",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/kwordquiz-25.12.3.tar.xz",
                    "sha256": "fb98383c0b921253a4e4c06c16b96019a0d629b413e6451db64d69889f52cf52",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kwordquiz-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
